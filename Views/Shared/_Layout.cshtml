@inject SIBA.ComplaintSystem.Data.ApplicationDbContext _db
@{
    var currentUserId = User.FindFirst("UserId")?.Value;
    var profilePath = string.Empty;
    if (!string.IsNullOrEmpty(currentUserId))
    {
        profilePath = _db.Users.FirstOrDefault(u => u.Id == int.Parse(currentUserId))?.ProfilePicturePath;
    }
}
<!DOCTYPE html>
<html lang="en" class="h-full bg-gray-50">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SIBA Complaint System</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/SIBA.ComplaintSystem.styles.css" asp-append-version="true" />
    @* Add Google Fonts: Inter *@
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; }
    </style>
</head>
<body class="h-full flex overflow-hidden">

    <!-- Sidebar -->
    <aside class="hidden md:flex md:flex-shrink-0">
        <div class="flex flex-col w-64 bg-white border-r border-gray-200">
            <!-- Sidebar Header / Logo -->
            <div class="flex items-center h-16 flex-shrink-0 px-4 border-b border-gray-200 space-x-3">
                <div class="w-8 h-8 bg-primary-600 rounded-lg flex items-center justify-center text-white font-bold text-sm">S</div>
                <span class="text-xl font-bold text-gray-900 tracking-tight">SIBA HelpDesk</span>
            </div>

            <!-- Sidebar Links -->
            <div class="flex-1 flex flex-col overflow-y-auto pt-5 pb-4">
                <nav class="flex-1 px-2 space-y-1">
                    @if (User.Identity.IsAuthenticated)
                    {
                        var ctrl = ViewContext.RouteData.Values["Controller"]?.ToString();
                        var act = ViewContext.RouteData.Values["Action"]?.ToString();

                        <a asp-controller="Home" asp-action="Index" class="group flex items-center px-2 py-2 text-sm font-medium rounded-md @(ctrl == "Home" && act == "Index" ? "text-gray-900 bg-gray-100" : "text-gray-600 hover:bg-gray-50 hover:text-gray-900")">
                            <svg class="mr-3 h-6 w-6 @(ctrl == "Home" && act == "Index" ? "text-gray-600" : "text-gray-400 group-hover:text-gray-500")" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
                            </svg>
                            Dashboard
                        </a>

                        @if (!User.IsInRole("Admin"))
                        {
                            <a asp-controller="Home" asp-action="Create" class="group flex items-center px-2 py-2 text-sm font-medium rounded-md @(ctrl == "Home" && act == "Create" ? "text-gray-900 bg-gray-100" : "text-gray-600 hover:bg-gray-50 hover:text-gray-900")">
                                <svg class="mr-3 h-6 w-6 @(ctrl == "Home" && act == "Create" ? "text-gray-600" : "text-gray-400 group-hover:text-gray-500")" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
                                </svg>
                                New Complaint
                            </a>
                        }

                        @if (User.IsInRole("Admin"))
                        {
                            <div class="pt-4 pb-2 px-2 text-xs font-semibold text-gray-500 uppercase tracking-wider">Administration</div>
                            <a asp-controller="Admin" asp-action="Index" class="group flex items-center px-2 py-2 text-sm font-medium rounded-md @(ctrl == "Admin" && act == "Index" ? "text-primary-700 bg-primary-50" : "text-gray-600 hover:bg-primary-50 hover:text-primary-700 transition-colors")">
                                <svg class="mr-3 h-6 w-6 @(ctrl == "Admin" && act == "Index" ? "text-primary-700" : "text-gray-400 group-hover:text-primary-500")" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
                                </svg>
                                Complaint Management
                            </a>
                            @if (User.Claims.Any(c => c.Type == System.Security.Claims.ClaimTypes.Email && c.Value == "senior@admin.siba.edu.pk"))
                            {
                                <a asp-controller="Admin" asp-action="CreateAdmin" class="group flex items-center px-2 py-2 text-sm font-medium rounded-md @(ctrl == "Admin" && act == "CreateAdmin" ? "text-primary-700 bg-primary-50" : "text-gray-600 hover:bg-primary-50 hover:text-primary-700 transition-colors")">
                                    <svg class="mr-3 h-6 w-6 @(ctrl == "Admin" && act == "CreateAdmin" ? "text-primary-700" : "text-gray-400 group-hover:text-primary-500")" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z" />
                                    </svg>
                                    Add Staff
                                </a>
                                <a asp-controller="Admin" asp-action="ManageStaff" class="group flex items-center px-2 py-2 text-sm font-medium rounded-md @(ctrl == "Admin" && act == "ManageStaff" ? "text-primary-700 bg-primary-50" : "text-gray-600 hover:bg-primary-50 hover:text-primary-700 transition-colors")">
                                    <svg class="mr-3 h-6 w-6 @(ctrl == "Admin" && act == "ManageStaff" ? "text-primary-700" : "text-gray-400 group-hover:text-primary-500")" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
                                    </svg>
                                    Manage Staff
                                </a>
                                <a asp-controller="Admin" asp-action="Resolved" class="group flex items-center px-1 py-1 text-xs font-bold rounded-lg mt-4 border border-dashed border-gray-200 @(ctrl == "Admin" && act == "Resolved" ? "text-green-700 bg-green-50 border-green-200" : "text-gray-400 hover:text-green-600 hover:bg-green-50 transition-colors")">
                                    <svg class="mr-3 h-5 w-5 @(ctrl == "Admin" && act == "Resolved" ? "text-green-600" : "text-gray-300 group-hover:text-green-500")" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4" />
                                    </svg>
                                    Resolved Archives
                                </a>
                            }
                        }

                        <div class="pt-4 pb-2 px-2 text-xs font-semibold text-gray-400 uppercase tracking-widest">Personal</div>
                        <a asp-controller="Account" asp-action="Settings" class="group flex items-center px-2 py-2 text-sm font-medium rounded-md @(ctrl == "Account" && act == "Settings" ? "text-primary-700 bg-primary-50" : "text-gray-600 hover:bg-primary-50 hover:text-primary-700 transition-colors")">
                            <svg class="mr-3 h-6 w-6 @(ctrl == "Account" && act == "Settings" ? "text-primary-700" : "text-gray-400 group-hover:text-primary-500")" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                            </svg>
                            Account Settings
                        </a>
                    }
                    else
                    {
                        <a asp-controller="Account" asp-action="Auth" class="group flex items-center px-2 py-2 text-sm font-medium rounded-md text-primary-600 bg-primary-50">
                            <svg class="mr-3 h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 16l-4-4m0 0l4-4m-4 4h14m-5 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h7a3 3 0 013 3v1" />
                            </svg>
                            Portal Login
                        </a>
                    }
                </nav>
            </div>

            <!-- Sidebar Footer / SIBA Branding -->
            <div class="p-4 border-t border-gray-200">
                <div class="flex items-center space-x-3">
                    @if (User.IsInRole("Admin"))
                    {
                        <div class="w-10 h-10 rounded-full bg-gray-100 flex items-center justify-center font-bold text-gray-400 text-xs">SIBA</div>
                    }
                    else
                    {
                        <div class="w-10 h-10 rounded-full bg-primary-100 flex items-center justify-center font-bold text-primary-600 text-xs shadow-inner">SIBA</div>
                    }
                    <div>
                        <p class="text-sm font-medium text-gray-900">Sukkur IBA</p>
                        <p class="text-xs text-gray-500">University Portal</p>
                    </div>
                </div>
            </div>
        </div>
    </aside>

    <!-- Main Section -->
    <div class="flex flex-col flex-1 overflow-hidden">
        <!-- Top Headerbar -->
        <header class="h-16 bg-white border-b border-gray-200 flex items-center justify-between px-6 flex-shrink-0">
            <h1 class="text-lg font-semibold text-gray-800">@ViewData["Title"]</h1>
            <div class="flex items-center space-x-4">
                @if (User.Identity.IsAuthenticated)
                {
                    <div class="flex items-center space-x-3 mr-4 border-r border-gray-200 pr-4">
                        <div class="text-right">
                            <p class="text-sm font-bold text-gray-900">@User.Identity.Name</p>
                            <p class="text-xs text-gray-500">@User.Claims.FirstOrDefault(c => c.Type == System.Security.Claims.ClaimTypes.Role)?.Value</p>
                        </div>
                        <div class="h-10 w-10 rounded-xl bg-primary-600 overflow-hidden flex items-center justify-center text-white text-sm font-bold shadow-md shadow-primary-100 border-2 border-white">
                            @if (string.IsNullOrEmpty(profilePath))
                            {
                                <span>@User.Identity.Name?.Substring(0, 1).ToUpper()</span>
                            }
                            else
                            {
                                <img src="@profilePath" class="w-full h-full object-cover" alt="Profile" />
                            }
                        </div>
                    </div>
                    <a asp-controller="Account" asp-action="Logout" class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-lg text-red-700 bg-red-50 hover:bg-red-100 transition-colors">
                        Logout
                    </a>
                }
                else
                {
                    <a asp-controller="Account" asp-action="Auth" class="inline-flex items-center px-5 py-2 border border-transparent text-sm font-bold rounded-xl text-white bg-primary-600 hover:bg-primary-700 shadow-lg shadow-primary-100 transition-all active:scale-95">
                        Access Portal
                    </a>
                }
            </div>
        </header>

        <!-- Dynamic Content -->
        <main class="flex-1 overflow-y-auto p-8">
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="max-w-4xl mx-auto mb-6 bg-green-50 border border-green-200 text-green-800 px-4 py-3 rounded-xl flex items-center space-x-3 shadow-sm animate-in fade-in slide-in-from-top-4 duration-300">
                    <svg class="h-5 w-5 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                    </svg>
                    <span class="font-medium">@TempData["SuccessMessage"]</span>
                </div>
            }
            @if (ViewBag.Error != null)
            {
                <div class="max-w-4xl mx-auto mb-6 bg-red-50 border border-red-200 text-red-800 px-4 py-3 rounded-xl flex items-center space-x-3 shadow-sm animate-in fade-in slide-in-from-top-4 duration-300">
                    <svg class="h-5 w-5 text-red-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                    <span class="font-medium">@ViewBag.Error</span>
                </div>
            }
            @RenderBody()
        </main>

        <!-- Simple Footer -->
        <footer class="px-8 py-4 bg-white border-t border-gray-200 text-sm text-gray-500 flex justify-between">
            <span>&copy; 2026 Sukkur IBA University (SIBA)</span>
            <div class="space-x-4">
                <a asp-controller="Home" asp-action="Privacy" class="hover:text-gray-700 underline">Privacy Policy</a>
                <span>Complaint Management System</span>
            </div>
        </footer>
    </div>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
