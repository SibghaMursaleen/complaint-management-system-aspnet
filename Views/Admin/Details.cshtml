@model SIBA.ComplaintSystem.Models.Complaint
@{
    ViewData["Title"] = "Discussion Detail";
    var messages = ViewBag.Messages as List<SIBA.ComplaintSystem.Models.ComplaintMessage> ?? new List<SIBA.ComplaintSystem.Models.ComplaintMessage>();
    var studentName = Model.IsAnonymous ? "Anonymous Student" : Model.User?.Username ?? "Unknown User";
}

<div class="max-w-6xl mx-auto space-y-6 pb-20">
    <!-- Header: Action Bar -->
    <div class="flex items-center justify-between">
        <nav class="flex items-center space-x-2 text-sm text-gray-500 font-medium">
            <a asp-action="Index" class="hover:text-primary-600 transition-colors">Complaints</a>
            <svg style="width: 14px; height: 14px;" class="h-3.5 w-3.5 flex-shrink-0 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
            <span class="text-gray-900">Discussion with @studentName</span>
        </nav>
        <div class="flex items-center space-x-3">
             <form asp-action="UpdateStatus" method="post" class="flex items-center space-x-2">
                <input type="hidden" name="id" value="@Model.Id" />
                <span class="text-xs font-bold text-gray-400 uppercase tracking-widest mr-2">Update Status:</span>
                <select name="status" onchange="this.form.submit()" class="text-xs font-bold rounded-lg border-gray-200 shadow-sm focus:border-primary-600 focus:ring-primary-600 py-2 px-4 border bg-white text-gray-700 cursor-pointer">
                    <option value="Pending" selected='@(Model.Status == "Pending")'>PENDING</option>
                    <option value="In Progress" selected='@(Model.Status == "In Progress")'>PROCESSING</option>
                    <option value="Resolved" selected='@(Model.Status == "Resolved")'>RESOLVED</option>
                </select>
            </form>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-4 gap-6">
        <!-- Student Info & Ticket Meta -->
        <div class="space-y-6">
            <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6">
                <h3 class="text-sm font-bold text-gray-900 mb-4 uppercase tracking-wider border-b border-gray-50 pb-2">Student Profile</h3>
                @if (Model.IsAnonymous)
                {
                    <div class="flex flex-col items-center text-center py-4">
                        <div class="h-16 w-16 rounded-full bg-gray-100 flex items-center justify-center text-gray-400 mb-3">
                            <svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" /></svg>
                        </div>
                        <p class="text-sm font-bold text-gray-500 italic">Identity Hidden</p>
                        <p class="text-[10px] text-gray-400 mt-1 uppercase leading-tight font-medium">This student chose to remain anonymous.</p>
                    </div>
                }
                else
                {
                    <div class="flex items-start space-x-3 mb-6">
                        <div style="min-width: 48px; min-height: 48px; width: 48px; height: 48px;" class="flex-shrink-0 rounded-xl bg-primary-600 flex items-center justify-center text-white font-bold text-lg shadow-inner">
                            @Model.User?.Username?.Substring(0, 1).ToUpper()
                        </div>
                        <div class="min-w-0 flex-1">
                            <p class="text-sm font-bold text-gray-900 break-words leading-tight">@Model.User?.Username</p>
                            <p class="text-xs text-gray-400 break-all mt-0.5">@Model.User?.Email</p>
                        </div>
                    </div>
                    <div class="space-y-4 pt-4 border-t border-gray-50">
                        <div>
                            <label class="text-[9px] font-extrabold text-gray-400 uppercase tracking-widest block mb-0.5">Student ID</label>
                            <p class="text-sm font-bold text-gray-700">@Model.StudentId</p>
                        </div>
                        <div>
                            <label class="text-[9px] font-extrabold text-gray-400 uppercase tracking-widest block mb-0.5">Department</label>
                            <p class="text-sm font-bold text-gray-700">@Model.StudentDepartment</p>
                        </div>
                        <div>
                            <label class="text-[9px] font-extrabold text-gray-400 uppercase tracking-widest block mb-0.5">Contact</label>
                            <p class="text-sm font-bold text-gray-700">@Model.ContactNumber</p>
                        </div>
                    </div>
                }
            </div>

            <div class="bg-indigo-950 rounded-2xl shadow-xl p-6 text-white border border-indigo-900">
                <h3 class="text-[10px] font-black text-indigo-300 mb-4 uppercase tracking-[0.2em]">Complaint Context</h3>
                <div class="space-y-4">
                    <div class="flex flex-col">
                        <label class="text-[9px] font-bold text-indigo-400 uppercase tracking-widest leading-loose">Priority Level</label>
                        <span class="text-sm font-extrabold text-white">@Model.Priority</span>
                    </div>
                    <div class="flex flex-col">
                        <label class="text-[9px] font-bold text-indigo-400 uppercase tracking-widest leading-loose">Target Department</label>
                        <span class="text-sm font-extrabold text-white">@Model.TargetDepartment</span>
                    </div>
                    <div class="flex flex-col">
                        <label class="text-[9px] font-bold text-indigo-400 uppercase tracking-widest leading-loose">Incident Location</label>
                        <span class="text-sm font-extrabold text-white">@Model.Location</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Discussion Board -->
        <div class="lg:col-span-3 space-y-6">
            <!-- Complaint Focus -->
            <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6 border-l-4 border-l-primary-500">
                <div class="flex justify-between items-start mb-2">
                    <h2 class="text-xl font-extrabold text-gray-900">@Model.Title</h2>
                    <span class="text-[10px] bg-slate-100 text-slate-500 px-2 py-1 rounded font-bold uppercase">Filed @Model.CreatedAt.ToString("MMM dd")</span>
                </div>
                <p class="text-sm text-gray-700 leading-relaxed">@Model.Description</p>
                @if (!string.IsNullOrEmpty(Model.AttachmentPath))
                {
                    <div class="mt-4">
                        <a href="@Model.AttachmentPath" target="_blank" class="inline-flex items-center px-4 py-2 rounded-lg bg-primary-50 text-primary-700 text-xs font-bold hover:bg-primary-100 transition-colors">
                            <svg class="h-4 w-4 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.172 7l-6.586 6.586a2 2 0 102.828 2.828l6.414-6.586a4 4 0 00-5.656-5.656l-6.415 6.585a6 6 0 108.486 8.486L20.5 13" /></svg>
                            View Evidence Attachment
                        </a>
                    </div>
                }
            </div>

            <!-- Thread -->
            <div class="space-y-4 bg-gray-50/50 p-6 rounded-3xl border border-gray-100">
                 @if (!messages.Any())
                {
                    <div class="text-center py-16 bg-white rounded-2xl border border-dashed border-gray-200">
                        <div class="h-16 w-16 bg-slate-50 rounded-full flex items-center justify-center mx-auto mb-4 shadow-inner">
                             <svg class="h-8 w-8 text-slate-300" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" /></svg>
                        </div>
                        <p class="text-sm text-slate-600 font-extrabold">No Messages Yet</p>
                        <p class="text-[11px] text-slate-400 font-medium max-w-[200px] mx-auto mt-1">Start the conversation by sending a followup or status update below.</p>
                    </div>
                }
                else
                {
                    @foreach (var msg in messages)
                    {
                        var isMe = msg.Sender?.Role == "Admin";
                        <div class="flex @(isMe ? "justify-end" : "justify-start")">
                            <div class="max-w-[85%] flex flex-col @(isMe ? "items-end" : "items-start")">
                                <div class="flex items-center space-x-2 mb-1">
                                    <span class="text-[10px] font-extrabold uppercase tracking-tight @(isMe ? "text-primary-600" : "text-gray-400")">
                                        @(isMe ? "STAFF RESPONSE" : (Model.IsAnonymous ? "ANONYMOUS STUDENT" : Model.User?.Username))
                                    </span>
                                    <span class="text-[9px] text-gray-300">@msg.SentAt.ToString("MMM dd, HH:mm")</span>
                                </div>
                                <div class="px-5 py-3 rounded-2xl text-sm shadow-sm @(isMe ? "bg-slate-900 text-white rounded-tr-none" : "bg-white border border-gray-100 text-gray-800 rounded-tl-none")">
                                    @msg.Content
                                </div>
                            </div>
                        </div>
                    }
                }
            </div>

            <!-- Reply Box -->
            <div id="reply-box-container">
                @if (Model.Status == "Resolved")
                {
                    <div class="bg-slate-50 border border-slate-100 rounded-2xl p-8 text-center space-y-2">
                        <div class="h-10 w-10 bg-white rounded-full shadow-sm flex items-center justify-center mx-auto text-slate-400">
                             <svg style="width: 20px; height: 20px;" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" /></svg>
                        </div>
                        <p class="text-[10px] font-black text-slate-400 uppercase tracking-[0.2em]">Discussion Archived</p>
                        <p class="text-[11px] text-slate-500 font-medium">This ticket is officially resolved. Interaction is locked to preserve history.</p>
                    </div>
                }
                else
                {
                    <div class="bg-white rounded-2xl shadow-xl border border-gray-100 overflow-hidden">
                        <form asp-action="AddMessage" method="post">
                            <input type="hidden" name="complaintId" value="@Model.Id" />
                            <textarea name="content" rows="4" class="w-full p-6 border-none focus:ring-0 text-sm placeholder-gray-400" placeholder="Type your reply or follow-up questions here..."></textarea>
                            <div class="p-4 bg-gray-50 border-t border-gray-100 flex justify-between items-center">
                                <p class="text-[10px] text-gray-400 font-bold italic uppercase tracking-wider">Messages are recorded for accountability</p>
                                <button type="submit" class="bg-primary-600 text-white px-8 py-3 rounded-xl text-xs font-extrabold shadow-lg shadow-primary-100 hover:bg-primary-700 transition-all active:scale-95 flex items-center space-x-2">
                                    <span>Post Reply</span>
                                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" /></svg>
                                </button>
                            </div>
                        </form>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
