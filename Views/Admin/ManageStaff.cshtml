@model IEnumerable<SIBA.ComplaintSystem.Models.User>

@{
    ViewData["Title"] = "Manage Staff";
}

<div class="space-y-6">
    <div class="flex items-center justify-between">
        <div class="space-y-1">
            <h2 class="text-2xl font-extrabold text-gray-900 capitalize leading-tight">Manage Staff</h2>
            <p class="text-sm text-gray-500 font-medium tracking-tight">View and remove staff accounts</p>
        </div>
        <div class="flex items-center space-x-3">
            <a asp-controller="Admin" asp-action="Index" class="inline-flex items-center justify-center px-6 py-2.5 bg-slate-200 text-slate-800 hover:bg-slate-300 rounded-full text-sm font-bold shadow-sm transition-all active:scale-95">
                <i class="fa-solid fa-arrow-left mr-2"></i>
                <span>Back to Dashboard</span>
            </a>
            <a asp-controller="Admin" asp-action="CreateAdmin" class="inline-flex items-center justify-center px-6 py-2.5 bg-primary-600 text-white rounded-full text-sm font-bold shadow-lg shadow-primary-200 hover:bg-primary-700 transition-all active:scale-95">
                <i class="fa-solid fa-plus mr-2"></i>
                <span>Add Staff</span>
            </a>
        </div>
    </div>

    <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
        <table class="min-w-full divide-y divide-gray-200">
            <thead class="bg-gray-50">
                <tr>
                    <th class="px-6 py-4 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Staff Details</th>
                    <th class="px-6 py-4 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Role</th>
                    <th class="px-6 py-4 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Added On</th>
                    <th class="px-6 py-4 text-right text-xs font-semibold text-gray-500 uppercase tracking-wider">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-200 bg-white">
                @foreach (var item in Model)
                {
                    <tr class="hover:bg-gray-50 transition-colors">
                        <td class="px-6 py-4">
                            <div class="text-sm font-bold text-gray-900">@item.Username</div>
                            <div class="text-xs text-gray-500">@item.Email</div>
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap">
                            <span class="bg-indigo-100 text-indigo-800 px-2 py-0.5 rounded text-xs font-medium uppercase tracking-tight">@item.Role</span>
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                            @item.CreatedAt.ToString("MMM dd, yyyy")
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                            <form asp-action="DeleteStaff" method="post" onsubmit="return confirm('Are you sure you want to delete this staff member? This action cannot be undone.');">
                                <input type="hidden" name="id" value="@item.Id" />
                                <button type="submit" class="text-red-600 hover:text-red-900 font-bold px-3 py-1 bg-red-50 hover:bg-red-100 rounded-lg transition-colors">
                                    <i class="fa-solid fa-trash-can mr-1"></i> Remove
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    
    @if (!Model.Any())
    {
        <div class="px-6 py-12 text-center text-gray-500 bg-white rounded-xl border border-dashed border-gray-300">
            No subadmin accounts found in the system.
        </div>
    }
</div>
