@model SIBA.ComplaintSystem.Models.User
@{
    ViewData["Title"] = "Account Settings";
}

<div class="max-w-4xl mx-auto space-y-12 animate-in fade-in duration-500 py-6">
    <!-- Header -->
    <div class="flex items-end justify-between border-b border-gray-100 pb-6">
        <div>
            <h1 class="text-3xl font-extrabold text-gray-900 tracking-tight">Account Settings</h1>
            <p class="text-gray-500 mt-1">Manage your personal information, security, and profile logo.</p>
        </div>
        <div class="text-right">
            <span class="inline-flex items-center rounded-full bg-primary-50 px-3 py-1 text-xs font-bold text-primary-700 ring-1 ring-inset ring-primary-600/20">
                @Model.Role Account
            </span>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="bg-green-50 border-l-4 border-green-400 p-4 rounded-r-xl shadow-sm animate-in slide-in-from-top-4">
            <div class="flex">
                <div class="flex-shrink-0">
                    <svg class="h-5 w-5 text-green-400" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" /></svg>
                </div>
                <div class="ml-3">
                    <p class="text-sm font-bold text-green-800">@TempData["SuccessMessage"]</p>
                </div>
            </div>
        </div>
    }

    @if (TempData["Error"] != null || ViewBag.Error != null)
    {
        <div class="bg-red-50 border-l-4 border-red-400 p-4 rounded-r-xl shadow-sm animate-in slide-in-from-top-4">
            <div class="flex">
                <div class="flex-shrink-0">
                    <svg class="h-5 w-5 text-red-400" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" /></svg>
                </div>
                <div class="ml-3">
                    <p class="text-sm font-bold text-red-800">@(TempData["Error"] ?? ViewBag.Error)</p>
                </div>
            </div>
        </div>
    }

    <form asp-action="UpdateSettings" method="post" enctype="multipart/form-data" class="grid grid-cols-1 md:grid-cols-3 gap-12">
        <!-- Sidebar: Profile Picture -->
        <div class="space-y-6">
            <div class="bg-white p-6 rounded-3xl shadow-sm border border-gray-100 text-center space-y-4">
                <div class="relative inline-block group">
                    <div class="w-32 h-32 rounded-3xl overflow-hidden bg-gray-50 border-4 border-white shadow-md ring-1 ring-gray-100 mx-auto">
                        @if (string.IsNullOrEmpty(Model.ProfilePicturePath))
                        {
                            <div class="w-full h-full flex items-center justify-center bg-primary-50 text-primary-600">
                                <span class="text-4xl font-black">@Model.Username.Substring(0, 1).ToUpper()</span>
                            </div>
                        }
                        else
                        {
                            <img src="@Model.ProfilePicturePath" alt="Profile" class="w-full h-full object-cover" />
                        }
                    </div>
                </div>
                <div>
                    <h3 class="text-sm font-bold text-gray-900">Profile Logo</h3>
                    <p class="text-[10px] text-gray-400 mt-1 uppercase font-black tracking-widest">JPG, PNG or GIF. Max 5MB.</p>
                </div>
                <div class="pt-2">
                    <label class="cursor-pointer bg-white border border-gray-200 px-4 py-2 rounded-xl text-xs font-bold text-gray-700 hover:bg-gray-50 transition-all shadow-sm flex items-center justify-center space-x-2">
                        <svg class="h-4 w-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12" /></svg>
                        <span>Change Image</span>
                        <input type="file" name="profilePicture" class="hidden" accept="image/*" />
                    </label>
                </div>
            </div>
        </div>

        <!-- Main Settings Form -->
        <div class="md:col-span-2 space-y-10">
            <!-- General Info -->
            <div class="bg-white p-10 rounded-[2rem] shadow-sm border border-gray-100 space-y-8">
                <div>
                    <h2 class="text-lg font-bold text-gray-900 flex items-center space-x-2">
                        <svg class="h-5 w-5 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" /></svg>
                        <span>Personal Information</span>
                    </h2>
                </div>

                <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                    <div class="space-y-1">
                        <label class="text-[10px] font-extrabold text-gray-400 uppercase tracking-widest block ml-1">Username</label>
                        <input type="text" name="username" value="@Model.Username" required class="w-full bg-gray-50 border-gray-100 rounded-xl px-4 py-2 text-sm focus:ring-primary-500 focus:border-primary-500 transition-all" />
                    </div>
                    <div class="space-y-1">
                        <label class="text-[10px] font-extrabold text-gray-400 uppercase tracking-widest block ml-1">Email Address</label>
                        <input type="email" name="email" value="@Model.Email" required class="w-full bg-gray-50 border-gray-100 rounded-xl px-4 py-2 text-sm focus:ring-primary-500 focus:border-primary-500 transition-all focus:bg-white" />
                        <p class="text-[9px] text-gray-400 mt-1 italic ml-1">* Changing email may affect your login credentials.</p>
                    </div>
                </div>
            </div>

            <!-- Security Section -->
            <div class="bg-white p-10 rounded-[2rem] shadow-sm border border-gray-100 space-y-8">
                <div>
                    <h2 class="text-lg font-bold text-gray-900 flex items-center space-x-2">
                        <svg class="h-5 w-5 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" /></svg>
                        <span>Security \ Reset Password</span>
                    </h2>
                    <p class="text-xs text-gray-500 mt-1 ml-7">Leave password fields blank if you don't wish to change them.</p>
                </div>

                <div class="space-y-6">
                    <div class="space-y-1">
                        <label class="text-[10px] font-extrabold text-gray-400 uppercase tracking-widest block ml-1">Current Password</label>
                        <input type="password" name="currentPassword" placeholder="••••••••" class="w-full bg-gray-50 border-gray-100 rounded-xl px-4 py-2 text-sm focus:ring-primary-500 focus:border-primary-500 transition-all" />
                    </div>
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                        <div class="space-y-1">
                            <label class="text-[10px] font-extrabold text-gray-400 uppercase tracking-widest block ml-1">New Password</label>
                            <input type="password" name="newPassword" placeholder="Enter new password" class="w-full bg-gray-50 border-gray-100 rounded-xl px-4 py-2 text-sm focus:ring-primary-500 focus:border-primary-500 transition-all" />
                        </div>
                        <div class="space-y-1">
                            <label class="text-[10px] font-extrabold text-gray-400 uppercase tracking-widest block ml-1">Confirm New Password</label>
                            <input type="password" name="confirmPassword" placeholder="Confirm new password" class="w-full bg-gray-50 border-gray-100 rounded-xl px-4 py-2 text-sm focus:ring-primary-500 focus:border-primary-500 transition-all" />
                        </div>
                    </div>
                </div>
            </div>

            <!-- Actions -->
            <div class="flex items-center justify-end pt-12" style="gap: 2rem;">
                <a href="@(Model.Role == "Admin" ? "/Admin" : "/")" class="rounded-2xl text-sm font-bold text-gray-400 hover:text-gray-600 transition-all uppercase tracking-widest" style="padding: 1.25rem 2rem;">Discard</a>
                <button type="submit" class="bg-primary-600 text-white font-black shadow-2xl shadow-primary-200 hover:bg-primary-700 hover:-translate-y-1 transition-all active:scale-95 leading-none tracking-wider" style="padding: 1.5rem 4rem; border-radius: 1.5rem; font-size: 1.125rem;">
                    Save Changes
                </button>
            </div>
        </div>
    </form>
</div>
