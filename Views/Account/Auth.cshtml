@model SIBA.ComplaintSystem.Models.User
@{
    Layout = null;
    bool isLogin = ViewBag.IsLogin ?? true;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Authentication - SIBA HelpDesk</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <style>
        body {
            background-color: #ffffff;
        }
        .form-input {
            background-color: #f8fafc;
            border: 1px solid #e2e8f0;
            transition: all 0.2s ease-in-out;
        }
        .form-input:focus {
            background-color: #ffffff;
            border-color: #4f46e5; /* primary-600 */
            box-shadow: 0 0 0 4px rgba(79, 70, 229, 0.1);
        }
    </style>
</head>
<body class="font-sans text-slate-900 antialiased">
    <div class="min-h-screen flex flex-col items-center justify-center p-6 sm:p-12">
        <div class="w-full max-w-[440px] space-y-8">
            
            <!-- Logo Section -->
            <div class="flex items-center justify-center space-x-3 mb-6">
                <div class="w-10 h-10 bg-primary-600 rounded-xl flex items-center justify-center shadow-lg shadow-primary-200">
                    <svg class="w-6 h-6 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                        <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                </div>
                <span class="text-2xl font-extrabold tracking-tight text-slate-900">SIBA HelpDesk</span>
            </div>

            <!-- Unified Header & Role Selector -->
            <div class="text-center space-y-6 mb-2">
                <h1 id="auth-title" class="text-4xl font-extrabold tracking-tight text-slate-900 transition-all duration-300">@(isLogin ? "Welcome Back" : "Get Started")</h1>
                


                <!-- Bigger Role Selector Toggle -->
                <div class="relative bg-slate-100 p-1.5 rounded-full flex text-center font-bold text-base mx-auto shadow-inner w-72">
                    <div id="role-slider" class="absolute top-1.5 left-1.5 bottom-1.5 w-[calc(50%-6px)] bg-white rounded-full shadow border border-slate-200 transition-transform duration-300 ease-in-out transform translate-x-0"></div>
                    <button type="button" id="btn-student" onclick="setRole('Student')" class="relative flex-1 py-2.5 text-slate-900 transition-colors z-10 w-1/2">Student</button>
                    <button type="button" id="btn-admin" onclick="setRole('Admin')" class="relative flex-1 py-2.5 text-slate-500 transition-colors z-10 w-1/2">Admin</button>
                </div>
            </div>

            @if (ViewBag.Error != null)
            {
                <div class="bg-red-50 text-red-600 text-sm p-4 rounded-xl border border-red-100 flex items-start space-x-3">
                    <i class="fa-solid fa-circle-exclamation mt-0.5"></i>
                    <span>@ViewBag.Error</span>
                </div>
            }

            <!-- Signup Container -->
            <div id="signup-container" class="@(!isLogin ? "block" : "hidden") animate-in fade-in slide-in-from-bottom-4 duration-500">

                <form asp-action="SignUp" method="post" class="space-y-6">
                    <div class="space-y-2">
                        <label class="text-sm font-bold text-slate-700 ml-1">Name</label>
                        <input type="text" name="username" required
                               class="w-full px-5 py-4 rounded-xl form-input focus:outline-none text-slate-900 placeholder:text-slate-400"
                               placeholder="Enter your name">
                    </div>

                    <div class="space-y-2">
                        <label class="text-sm font-bold text-slate-700 ml-1">Email</label>
                        <input type="email" name="email" required pattern=".*@@iba-suk\.edu\.pk$" title="Please use a valid @@iba-suk.edu.pk student domain."
                               class="w-full px-5 py-4 rounded-xl form-input focus:outline-none text-slate-900 placeholder:text-slate-400"
                               placeholder="name@iba-suk.edu.pk">
                        <p class="text-xs text-primary-600 ml-1 font-medium">Must be a valid iba-suk.edu.pk address</p>
                    </div>

                    <div class="space-y-2">
                        <label class="text-sm font-bold text-slate-700 ml-1">Password</label>
                        <div class="relative">
                            <input type="password" name="password" id="signup-password" required
                                   class="w-full px-5 py-4 rounded-xl form-input focus:outline-none text-slate-900 placeholder:text-slate-400"
                                   placeholder="••••••••">
                            <button type="button" onclick="togglePassword('signup-password')" class="absolute right-4 top-1/2 -translate-y-1/2 text-slate-400 hover:text-slate-600">
                                <i class="fa-regular fa-eye-slash text-xl"></i>
                            </button>
                        </div>
                    </div>

                    <button type="submit" class="w-full py-4 bg-primary-600 text-white rounded-full font-bold text-lg shadow-lg shadow-primary-200 hover:bg-primary-700 hover:shadow-primary-300 transition-all active:scale-[0.98]">
                        Sign up
                    </button>
                    
                    <p id="login-switch-link" class="text-slate-500 font-medium text-center mt-6">
                        Already have an account? 
                        <a href="javascript:void(0)" onclick="toggleMode(true)" class="text-primary-600 font-semibold hover:text-primary-700 transition-colors">Sign in</a>
                    </p>
                </form>
            </div>

            <!-- Login Container -->
            <div id="login-container" class="@(isLogin ? "block" : "hidden") animate-in fade-in slide-in-from-bottom-4 duration-500">

                <form asp-action="Login" method="post" class="space-y-6">
                    <div class="space-y-2">
                        <label class="text-sm font-bold text-slate-700 ml-1">Email</label>
                        <input type="email" name="email" id="login-email" required
                               class="w-full px-5 py-4 rounded-xl form-input focus:outline-none text-slate-900 placeholder:text-slate-400"
                               placeholder="name@iba-suk.edu.pk">
                    </div>

                    <div class="space-y-2">
                        <label class="text-sm font-bold text-slate-700 ml-1">Password</label>
                        <div class="relative">
                            <input type="password" name="password" id="login-password" required
                                   class="w-full px-5 py-4 rounded-xl form-input focus:outline-none text-slate-900 placeholder:text-slate-400"
                                   placeholder="••••••••">
                            <button type="button" onclick="togglePassword('login-password')" class="absolute right-4 top-1/2 -translate-y-1/2 text-slate-400 hover:text-slate-600">
                                <i class="fa-regular fa-eye-slash text-xl"></i>
                            </button>
                        </div>
                    </div>


                    <div class="flex items-center justify-between px-1">
                        <label class="flex items-center space-x-2 cursor-pointer group">
                            <input type="checkbox" class="w-5 h-5 rounded border-slate-300 text-primary-600 focus:ring-primary-500 cursor-pointer">
                            <span class="text-sm font-medium text-slate-500 group-hover:text-slate-700 transition-colors">Remember me</span>
                        </label>
                        <a href="#" class="text-sm font-bold text-primary-600 hover:text-primary-700 transition-colors">Forgot password?</a>
                    </div>

                    <button type="submit" class="w-full py-4 bg-primary-600 text-white rounded-full font-bold text-lg shadow-lg shadow-primary-200 hover:bg-primary-700 hover:shadow-primary-300 transition-all active:scale-[0.98]">
                        Sign in
                    </button>
                    
                    <p id="signup-switch-link" class="text-slate-500 font-medium text-center mt-6 transition-opacity duration-300">
                        Don't have an account? 
                        <a href="javascript:void(0)" onclick="toggleMode(false)" class="text-primary-600 font-semibold hover:text-primary-700 transition-colors">Sign up</a>
                    </p>
                </form>
            </div>


        </div>
    </div>

    <script>
        let currentRole = 'Student';

        function setRole(role) {
            currentRole = role;
            const slider = document.getElementById('role-slider');
            const btnStudent = document.getElementById('btn-student');
            const btnAdmin = document.getElementById('btn-admin');
            const signupSwitch = document.getElementById('signup-switch-link');
            const loginEmail = document.getElementById('login-email');
            
            if (role === 'Admin') {
                slider.style.transform = 'translateX(100%)';
                btnStudent.classList.replace('text-slate-900', 'text-slate-500');
                btnAdmin.classList.replace('text-slate-500', 'text-slate-900');
                
                // Hide sign up option for admin
                if (signupSwitch) signupSwitch.style.opacity = '0';
                setTimeout(() => { if (signupSwitch) signupSwitch.style.visibility = 'hidden'; }, 300);
                
                // Update placeholder
                if (loginEmail) loginEmail.placeholder = 'name@@admin.siba.edu.pk';
                
                toggleMode(true); // Force to login if on signup
            } else {
                slider.style.transform = 'translateX(0)';
                btnAdmin.classList.replace('text-slate-900', 'text-slate-500');
                btnStudent.classList.replace('text-slate-500', 'text-slate-900');
                
                // Show sign up option for student
                if (signupSwitch) {
                    signupSwitch.style.visibility = 'visible';
                    signupSwitch.style.opacity = '1';
                }
                
                // Update placeholder
                if (loginEmail) loginEmail.placeholder = 'name@@iba-suk.edu.pk';
            }
        }

        function toggleMode(toLogin) {
            const loginContainer = document.getElementById('login-container');
            const signupContainer = document.getElementById('signup-container');
            const authTitle = document.getElementById('auth-title');

            if (toLogin) {
                loginContainer.classList.remove('hidden');
                signupContainer.classList.add('hidden');
                authTitle.innerText = "Welcome Back";
            } else {
                if (currentRole === 'Admin') return; // Prevent going to signup if admin
                signupContainer.classList.remove('hidden');
                loginContainer.classList.add('hidden');
                authTitle.innerText = "Get Started";
            }
        }

        function togglePassword(inputId) {
            const input = document.getElementById(inputId);
            const icon = input.nextElementSibling.querySelector('i');
            
            if (input.type === 'password') {
                input.type = 'text';
                icon.classList.remove('fa-eye-slash');
                icon.classList.add('fa-eye');
            } else {
                input.type = 'password';
                icon.classList.remove('fa-eye');
                icon.classList.add('fa-eye-slash');
            }
        }
    </script>
</body>
</html>
