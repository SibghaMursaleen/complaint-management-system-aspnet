@model IEnumerable<SIBA.ComplaintSystem.Models.Complaint>

@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="space-y-6">
    <div class="flex items-center justify-between">
        <div class="space-y-1">
            <h2 class="text-2xl font-extrabold text-gray-900 capitalize leading-tight">Student Complaints</h2>
            <p class="text-sm text-gray-500 font-medium tracking-tight">Manage and resolve active student tickets</p>
        </div>
        <div class="flex items-center space-x-3">
            @if (User.Claims.Any(c => c.Type == System.Security.Claims.ClaimTypes.Email && c.Value == "senior@admin.siba.edu.pk"))
            {
                <a asp-controller="Admin" asp-action="ManageStaff" class="inline-flex items-center justify-center px-6 py-2.5 bg-slate-200 text-slate-800 hover:bg-slate-300 rounded-full text-sm font-bold shadow-sm transition-all active:scale-95">
                    <i class="fa-solid fa-users mr-2"></i>
                    <span>Manage Staff</span>
                </a>
                <a asp-controller="Admin" asp-action="CreateAdmin" class="inline-flex items-center justify-center px-6 py-2.5 bg-primary-600 text-white rounded-full text-sm font-bold shadow-lg shadow-primary-200 hover:bg-primary-700 transition-all active:scale-95">
                    <i class="fa-solid fa-plus mr-2"></i>
                    <span>Add Staff</span>
                </a>
            }
            <div class="px-3 py-2 bg-slate-100 text-slate-800 rounded-full text-[10px] font-extrabold uppercase tracking-widest border border-slate-200">Staff Portal</div>
        </div>
    </div>

    <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
        <table class="min-w-full divide-y divide-gray-200">
            <thead class="bg-gray-50">
                <tr>
                    <th class="px-6 py-4 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Student & ID</th>
                    <th class="px-6 py-4 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Complaint Detail</th>
                    <th class="px-6 py-4 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Priority</th>
                    <th class="px-6 py-4 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Status</th>
                    <th class="px-6 py-4 text-xs font-semibold text-gray-500 uppercase tracking-wider text-right">Filed Date</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-200 bg-white border-b border-gray-200">
                @foreach (var item in Model)
                {
                    <tr class="hover:bg-gray-50 transition-colors">
                        <td class="px-6 py-4 whitespace-nowrap">
                            @if (item.IsAnonymous)
                            {
                                <div class="flex items-center space-x-3">
                                    <div class="h-8 w-8 rounded-full bg-gray-100 flex items-center justify-center text-gray-400">
                                        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" /></svg>
                                    </div>
                                    <span class="text-sm font-bold text-gray-500 italic">Anonymous Student</span>
                                </div>
                            }
                            else
                            {
                                <div class="flex items-center space-x-3">
                                    <div class="h-8 w-8 rounded-full bg-primary-100 flex items-center justify-center text-primary-700 font-bold text-xs uppercase">
                                        @item.User?.Username?.Substring(0, 1)
                                    </div>
                                    <div>
                                        <div class="text-sm font-bold text-gray-900">@item.User?.Username</div>
                                        <div class="text-[10px] text-gray-400 font-medium">ID: @item.StudentId</div>
                                    </div>
                                </div>
                            }
                        </td>
                        <td class="px-6 py-4">
                            <div class="flex flex-col">
                                <span class="text-sm font-bold text-gray-900">@item.Title</span>
                                <span class="text-xs text-gray-500 line-clamp-1 max-w-xs">@item.Description</span>
                                @if (!string.IsNullOrEmpty(item.AttachmentPath))
                                {
                                    <a href="@item.AttachmentPath" target="_blank" class="mt-1 inline-flex items-center text-[10px] font-bold text-primary-600 hover:text-primary-800 uppercase tracking-wider">
                                        <svg class="w-3 h-3 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.172 7l-6.586 6.586a2 2 0 102.828 2.828l6.414-6.586a4 4 0 00-5.656-5.656l-6.415 6.585a6 6 0 108.486 8.486L20.5 13" /></svg>
                                        View Attachment
                                    </a>
                                }
                            </div>
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap">
                            @{
                                var priorityColor = item.Priority switch {
                                    "High" => "bg-red-50 text-red-700 ring-red-600/20",
                                    "Medium" => "bg-orange-50 text-orange-700 ring-orange-600/20",
                                    _ => "bg-slate-50 text-slate-700 ring-slate-600/20"
                                };
                            }
                            <span class="inline-flex items-center rounded-md px-2 py-1 text-[10px] font-extrabold ring-1 ring-inset uppercase tracking-tight @priorityColor">
                                @item.Priority
                            </span>
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap">
                            <form asp-action="UpdateStatus" method="post" class="flex items-center">
                                <input type="hidden" name="id" value="@item.Id" />
                                <select name="status" onchange="this.form.submit()" class="text-[11px] font-bold rounded-lg border-gray-200 shadow-sm focus:border-primary-600 focus:ring-primary-600 py-1.5 px-3 border bg-white text-gray-700 transition-all cursor-pointer hover:bg-gray-50">
                                    <option value="Pending" selected='@(item.Status == "Pending")'>PENDING</option>
                                    <option value="In Progress" selected='@(item.Status == "In Progress")'>PROCESS</option>
                                    <option value="Resolved" selected='@(item.Status == "Resolved")'>RESOLVED</option>
                                </select>
                            </form>
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap text-right">
                             <a asp-action="Details" asp-route-id="@item.Id" class="inline-flex items-center px-4 py-2 bg-slate-800 text-white border border-slate-700 rounded-xl font-extrabold text-[10px] uppercase tracking-widest hover:bg-slate-700 transition-all active:scale-95 shadow-md shadow-slate-100">
                                Open Thread
                            </a>
                            <div class="text-[9px] font-bold text-slate-400 mt-1 uppercase tracking-tighter">Filed @item.CreatedAt.ToString("MMM dd")</div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    
    @if (!Model.Any())
    {
        <div class="px-6 py-12 text-center text-gray-500 bg-white rounded-xl border border-dashed border-gray-300">
            No complaints found in the system database.
        </div>
    }
</div>
