@model IEnumerable<SIBA.ComplaintSystem.Models.ComplaintArchive>
@{
    ViewData["Title"] = "Resolved Archives";
}

<div class="space-y-6">
    <div class="flex items-center justify-between">
        <div class="space-y-1">
            <h2 class="text-2xl font-extrabold text-gray-900 tracking-tight">Resolution Archives</h2>
            <p class="text-sm text-gray-500 font-medium">Permanent proof of resolved student tickets</p>
        </div>
        <div class="px-4 py-2 bg-green-50 text-green-700 rounded-full text-xs font-extrabold uppercase tracking-widest border border-green-100 flex items-center">
            <svg class="h-3 w-3 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
            Immutable Logs
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-16 text-center">
            <div class="inline-flex items-center justify-center w-20 h-20 bg-gray-50 rounded-full mb-6">
                <svg class="h-10 w-10 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
                </svg>
            </div>
            <h3 class="text-xl font-bold text-gray-900">No archives found</h3>
            <p class="mt-2 text-gray-500 max-w-sm mx-auto">Once a complaint is marked as 'Resolved', its proof log will automatically appear here.</p>
        </div>
    }
    else
    {
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
            <table class="min-w-full divide-y divide-gray-200">
                <thead class="bg-gray-50">
                    <tr>
                        <th class="px-6 py-4 text-left text-[10px] font-extrabold text-gray-400 uppercase tracking-widest">Ticket Information</th>
                        <th class="px-6 py-4 text-left text-[10px] font-extrabold text-gray-400 uppercase tracking-widest">Student</th>
                        <th class="px-6 py-4 text-left text-[10px] font-extrabold text-gray-400 uppercase tracking-widest">Resolution Date</th>
                        <th class="px-6 py-4 text-right text-[10px] font-extrabold text-gray-400 uppercase tracking-widest">Action</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-200 bg-white">
                    @foreach (var item in Model)
                    {
                        <tr class="hover:bg-gray-50/50 transition-colors">
                            <td class="px-6 py-5">
                                <div class="text-sm font-bold text-gray-900 mb-1">@item.ComplaintTitle</div>
                                <div class="flex items-center space-x-2">
                                    <span class="text-[10px] bg-slate-100 text-slate-500 px-1.5 py-0.5 rounded font-bold">#@item.ComplaintId</span>
                                    <span class="text-[10px] text-gray-400">Archived under @item.ResolvedBy</span>
                                </div>
                            </td>
                            <td class="px-6 py-5 whitespace-nowrap">
                                <div class="flex items-center space-x-2">
                                    <div class="h-6 w-6 rounded-full bg-slate-100 flex items-center justify-center text-[10px] font-bold text-slate-400">
                                        @item.StudentName.Substring(0, 1)
                                    </div>
                                    <span class="text-sm font-semibold text-gray-700">@item.StudentName</span>
                                </div>
                            </td>
                            <td class="px-6 py-5 whitespace-nowrap">
                                <div class="text-sm font-medium text-gray-600">@item.ResolvedAt.ToString("MMM dd, yyyy")</div>
                                <div class="text-[10px] text-gray-400">At @item.ResolvedAt.ToString("HH:mm")</div>
                            </td>
                            <td class="px-6 py-5 whitespace-nowrap text-right">
                                <a asp-action="ViewProof" asp-route-id="@item.Id" class="inline-flex items-center px-4 py-2 border border-slate-200 rounded-xl text-xs font-bold text-slate-700 bg-white hover:bg-slate-50 hover:border-slate-300 transition-all active:scale-95 shadow-sm">
                                    <svg style="width: 16px; height: 16px;" class="h-4 w-4 mr-2 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>
                                    View Proof Log
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
