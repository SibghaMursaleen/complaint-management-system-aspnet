@{
    ViewData["Title"] = "Dashboard";
}

<div class="space-y-6">
    <!-- Welcome Header -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-8">
        <h2 class="text-3xl font-bold text-gray-900">Welcome to SIBA HelpDesk</h2>
        <p class="mt-2 text-gray-600">Managing student and staff complaints efficiently at Sukkur IBA University.</p>
    </div>

    <!-- Stats Cards Grid -->
    <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4">
        <!-- New / Pending -->
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 flex items-center space-x-4">
            <div class="p-3 bg-blue-50 rounded-lg">
                <svg class="h-6 w-6 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" />
                </svg>
            </div>
            <div>
                <p class="text-sm font-medium text-gray-500">Pending</p>
                <p class="text-2xl font-bold text-gray-900">@ViewBag.Pending</p>
            </div>
        </div>

        <!-- In Progress -->
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 flex items-center space-x-4">
            <div class="p-3 bg-teal-50 rounded-lg">
                <svg class="h-6 w-6 text-teal-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
            </div>
            <div>
                <p class="text-sm font-medium text-gray-500">In Progress</p>
                <p class="text-2xl font-bold text-gray-900">@ViewBag.InProgress</p>
            </div>
        </div>

        <!-- Resolved -->
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 flex items-center space-x-4">
            <div class="p-3 bg-amber-50 rounded-lg">
                <svg class="h-6 w-6 text-amber-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
            </div>
            <div>
                <p class="text-sm font-medium text-gray-500">Resolved</p>
                <p class="text-2xl font-bold text-gray-900">@ViewBag.Resolved</p>
            </div>
        </div>

        <!-- Total -->
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 flex items-center space-x-4">
            <div class="p-3 bg-emerald-50 rounded-lg">
                <svg class="h-6 w-6 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
                </svg>
            </div>
            <div>
                <p class="text-sm font-medium text-gray-500">Total Filed</p>
                <p class="text-2xl font-bold text-gray-900">@ViewBag.Total</p>
            </div>
        </div>
    </div>

    <!-- Quick Actions Section -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
            <h3 class="text-lg font-bold text-gray-900 mb-4">Quick Actions</h3>
            <div class="grid grid-cols-2 gap-4">
                <a asp-controller="Home" asp-action="Create" class="flex flex-col items-center justify-center p-4 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors border border-gray-200">
                    <div class="w-10 h-10 bg-primary-600 rounded-full flex items-center justify-center text-white mb-2">
                        <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
                        </svg>
                    </div>
                    <span class="text-sm font-medium text-gray-700">New Ticket</span>
                </a>
                <a asp-controller="Home" asp-action="List" class="flex flex-col items-center justify-center p-4 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors border border-gray-200">
                    <div class="w-10 h-10 bg-gray-600 rounded-full flex items-center justify-center text-white mb-2">
                        <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 10h16M4 14h16M4 18h16" />
                        </svg>
                    </div>
                    <span class="text-sm font-medium text-gray-700">View All</span>
                </a>
            </div>
        </div>

        <!-- Help Info Section -->
        <div class="bg-primary-600 rounded-xl shadow-sm p-6 text-white relative overflow-hidden">
            <div class="relative z-10">
                <h3 class="text-lg font-bold mb-2 text-white">Need Assistance?</h3>
                <p class="text-primary-100 mb-4">If you're having trouble with the system, our help desk is available 24/7 at the main IBA campus.</p>
                <button class="bg-white text-primary-600 px-4 py-2 rounded-lg font-bold text-sm hover:bg-gray-100 transition-colors">Contact Support</button>
            </div>
            <!-- Decorative SVG circle -->
            <svg class="absolute -bottom-6 -right-6 w-32 h-32 text-primary-500 opacity-20" fill="currentColor" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/></svg>
        </div>
    </div>
</div>
